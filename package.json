{
    "name": "pathfinder-project",
    "version": "1.0.0",
    "description": "Pathfinder Fullstack Project",
    "main": "index.js",
    "scripts": {
        "install-all": "npm install --prefix frontend && pip install -r backend/requirements.txt",
        "frontend": "npm run dev --prefix frontend",
        "backend": "cd backend && .\\.venv\\Scripts\\python.exe manage.py runserver",
        "dev": "concurrently --names \"frontend,backend\" --prefix-colors \"cyan,green\" \"npm run frontend\" \"npm run backend\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}